# =============================================================================
# SubsBuzz Microservices - Environment Configuration Template
# =============================================================================
# Copy this file to .env.dev for development or .env.prod for production
# and fill in your actual credentials
#
# Architecture: Microservices (services/ directory)
# Database: PostgreSQL with Drizzle ORM
# =============================================================================

# -----------------------------------------------------------------------------
# Database Configuration (PostgreSQL)
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql://postgres:your_password@localhost:5432/subsbuzz_dev
POSTGRES_PASSWORD=your_secure_password
# Neon only: runtime services use the POOLER host (DATABASE_URL, hostname ends in
# `-pooler`). drizzle-kit migrations (npm run db:migrate) need the DIRECT host —
# PgBouncer pooling breaks session-level migration features. Set this to the same
# URL with `-pooler` removed. If unset, drizzle.config.ts derives it automatically.
# DATABASE_DIRECT_URL=postgresql://USER:PASS@ep-xxxx.REGION.aws.neon.tech/DB?sslmode=require

# -----------------------------------------------------------------------------
# Authentication & Security
# -----------------------------------------------------------------------------
JWT_SECRET=your-jwt-secret-key-make-it-long-and-random-at-least-32-chars
INTERNAL_API_SECRET=internal-api-secret-for-service-to-service-communication

# -----------------------------------------------------------------------------
# Google OAuth (Gmail Integration)
# -----------------------------------------------------------------------------
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-your-google-client-secret
OAUTH_REDIRECT_URI=http://localhost:8000/auth/callback

# -----------------------------------------------------------------------------
# External APIs (LLM providers)
# -----------------------------------------------------------------------------
# DeepSeek is the default provider for all users (TEEPER-139). This is a shared
# server-side key — the cost is borne by the operator, not individual users.
# DeepSeek is OpenAI-SDK compatible via baseURL override.
DEEPSEEK_API_KEY=sk-your-deepseek-api-key

# OpenAI is an opt-in per-user override. Each user who selects the OpenAI
# provider in Settings supplies their own key; this env var is only used as a
# fallback when a user picks 'openai' but hasn't pasted a personal key.
OPENAI_API_KEY=sk-proj-your-openai-api-key

# -----------------------------------------------------------------------------
# Redis Cache/Queue (for Celery email worker)
# -----------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0

# -----------------------------------------------------------------------------
# Service URLs & Ports
# -----------------------------------------------------------------------------
# Development defaults:
DATA_SERVER_PORT=3001
API_GATEWAY_PORT=8000
UI_PORT=5500

# Service communication URLs (adjust for production/Docker):
DATA_SERVER_URL=http://localhost:3001
API_GATEWAY_URL=http://localhost:8000

# -----------------------------------------------------------------------------
# CDN (Bunny pull zone for hero images)
# -----------------------------------------------------------------------------
# Leave empty to serve hero images directly from origin (/hero-cache/).
# Set to your Bunny pull zone hostname (no trailing slash) in production:
#   VITE_HERO_CDN_URL=https://subsbuzz-hero-images.b-cdn.net
VITE_HERO_CDN_URL=

# -----------------------------------------------------------------------------
# Environment
# -----------------------------------------------------------------------------
NODE_ENV=development

# -----------------------------------------------------------------------------
# Firebase Configuration (Optional - for frontend auth)
# -----------------------------------------------------------------------------
# FIREBASE_PROJECT_ID=your-project-id
# FIREBASE_API_KEY=your-api-key
# FIREBASE_APP_ID=your-app-id